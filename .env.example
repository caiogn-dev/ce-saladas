# =============================================================================
# CÊ SALADAS - CUSTOMER FRONTEND CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://web-production-3e83a.up.railway.app/api/v1
NEXT_PUBLIC_STORE_SLUG=ce-saladas

# Media URL - For product images and other media files
NEXT_PUBLIC_MEDIA_URL=https://web-production-3e83a.up.railway.app

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=wss://web-production-3e83a.up.railway.app/ws

# -----------------------------------------------------------------------------
# Site URL (for SEO)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://cesaladas.com.br

# -----------------------------------------------------------------------------
# Payment Gateway - Mercado Pago
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# HERE Maps API (Required for delivery map)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HERE_API_KEY=your-here-api-key

# -----------------------------------------------------------------------------
# Contact Information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=contato@cesaladas.com.br
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
